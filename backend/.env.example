# =====================================================================
# StockAcademia — BACKEND environment variables
# Copy to ".env" and fill in your own values. Never commit the real .env.
# =====================================================================

# ─── Server ──────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# ─── Database (PostgreSQL) ───────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/stockacademia

# ─── Auth / JWT ──────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Google Sign-In ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# ─── Paystack (NGN + USD payments) ───────────────────────────────────
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# ─── Flutterwave (legacy intl one-time upgrades) ─────────────────────
FLUTTERWAVE_SECRET_KEY=FLWSECK_TEST-your_flutterwave_secret_key
FLUTTERWAVE_WEBHOOK_HASH=your_flutterwave_webhook_hash

# ─── Pricing (one-time upgrade / certificate — optional) ─────────────
PREMIUM_PRICE_KOBO=450000
PRICING_USD_CENTS=1000
BOOKING_USD_30MIN=10
BOOKING_USD_60MIN=20
BOOKING_USD_WEEKLY=70
DEFAULT_MEETING_URL=

# ─── Market data ─────────────────────────────────────────────────────
FINNHUB_API_KEY=your_finnhub_api_key

# ─── Telegram ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=your_telegram_admin_chat_id
# Bot @username (without @) — shown in the dashboard "Link your Telegram" step.
TELEGRAM_BOT_USERNAME=YourStockAcademiaBot

# ═══════════════════════════════════════════════════════════════════
#  PHASE 1 — PREMIUM TIER (recurring subscriptions + AI features)
# ═══════════════════════════════════════════════════════════════════

# ─── Anthropic (Claude) — AI compare + portfolio analysis ────────────
# Key from https://console.anthropic.com  (SET A MONTHLY SPENDING CAP!)
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# ─── Paystack (pay-first Premium — no Plans/subscriptions needed) ────
# Public key (pk_test_ / pk_live_) from the Paystack dashboard.
PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
# Webhook signing secret. Paystack signs with your SECRET key, so set this
# to your Paystack secret key (or whatever you configure in the dashboard).
PAYSTACK_WEBHOOK_SECRET=sk_test_your_paystack_secret_key
# NOTE: No PAYSTACK_PLAN_CODE_* needed — Premium is a one-time charge per
# period (monthly/annual), not a recurring Paystack subscription.

# ═══════════════════════════════════════════════════════════════════
#  PHASE 2 — AI NEWS SCANNER
# ═══════════════════════════════════════════════════════════════════
#
# The News Scanner sources news by market — no paid news API needed:
#   • US tickers  → Finnhub company-news (reuses FINNHUB_API_KEY above)
#   • NGX / other → Google News RSS (free, no key, covers Nigerian outlets)
# Both work in production at zero data cost.

# ─── AI spend guardrail ──────────────────────────────────────────────
# Max AI tool calls (compare + portfolio + news combined) per user per day.
# A hard backstop on Anthropic cost on top of the global 6-24h result cache.
AI_DAILY_LIMIT=25
